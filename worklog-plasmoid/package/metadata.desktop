[Desktop Entry]
Name=Jira Worklog Calendar
Name[es]=Calendario de horas Jira
Comment=Weekly calendar of Jira worklogs with drag-to-log support
Comment[es]=Calendario semanal de horas registradas en Jira con drag para crear
Icon=view-calendar-week
Type=Service
ServiceTypes=Plasma/Applet

X-Plasma-API=declarativeappletscript
X-Plasma-MainScript=ui/main.qml
X-Plasma-StandAloneApp=false
X-Plasma-ProvidesTaskManager=false
X-Plasma-NotificationArea=false

X-KDE-PluginInfo-Author=Claude (Anthropic) for LSPaninka
X-KDE-PluginInfo-Email=
X-KDE-PluginInfo-Name=org.kde.plasma.jiraworklog
X-KDE-PluginInfo-Version=0.1.2
X-KDE-PluginInfo-Website=https://github.com/lspaninka/kde-todo-1
X-KDE-PluginInfo-Category=Utilities
X-KDE-PluginInfo-License=MIT
X-KDE-PluginInfo-EnabledByDefault=true
X-KDE-ServiceTypes=Plasma/Applet
