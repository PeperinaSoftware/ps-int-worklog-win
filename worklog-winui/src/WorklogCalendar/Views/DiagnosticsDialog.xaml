<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WorklogCalendar.Views.DiagnosticsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Diagnóstico (Jira + Clockify)"
    PrimaryButtonText="Cerrar"
    SecondaryButtonText="Limpiar log">
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">900</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
    </ContentDialog.Resources>
    <Grid Width="820" Height="540">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="NoWrap" FontFamily="Consolas" FontSize="11"
                     Background="Transparent" />
        </ScrollViewer>
    </Grid>
</ContentDialog>
