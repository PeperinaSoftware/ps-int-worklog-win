<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WorklogCalendar.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configuración"
    PrimaryButtonText="Guardar"
    SecondaryButtonText="Cancelar"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">760</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
    </ContentDialog.Resources>
    <Pivot x:Name="Tabs" Width="700">
        <PivotItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10" Padding="4,8,4,16">
                    <TextBlock Text="Modo de vista" Opacity="0.7" />
                    <RadioButtons x:Name="ViewModeChooser" SelectedIndex="0">
                        <x:String>9h  (09:00 – 18:00)</x:String>
                        <x:String>24h (00:00 – 24:00)</x:String>
                    </RadioButtons>

                    <TextBlock Text="Fuente por defecto" Opacity="0.7" Margin="0,8,0,0" />
                    <RadioButtons x:Name="SourceChooser" SelectedIndex="0">
                        <x:String>Jira</x:String>
                        <x:String>Jira / Clockify</x:String>
                        <x:String>Clockify</x:String>
                    </RadioButtons>

                    <TextBlock Text="Primer día de la semana" Opacity="0.7" Margin="0,8,0,0" />
                    <RadioButtons x:Name="FirstDayChooser" SelectedIndex="0">
                        <x:String>Domingo</x:String>
                        <x:String>Lunes</x:String>
                    </RadioButtons>

                    <Grid ColumnSpacing="8" RowSpacing="6" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <NumberBox x:Name="DailyTarget" Header="Objetivo diario (horas)"
                                   Minimum="0" Maximum="24" SmallChange="0.5"
                                   SpinButtonPlacementMode="Inline"
                                   Grid.Row="0" Grid.Column="0" />
                        <NumberBox x:Name="WinWidth" Header="Ancho ventana (px)" Minimum="600" Maximum="3840"
                                   SpinButtonPlacementMode="Inline"
                                   Grid.Row="0" Grid.Column="1" />
                        <NumberBox x:Name="WinHeight" Header="Alto ventana (px)" Minimum="400" Maximum="2160"
                                   SpinButtonPlacementMode="Inline"
                                   Grid.Row="1" Grid.Column="0" />
                        <CheckBox x:Name="AlwaysOnTop" Content="Mantener sobre otras ventanas"
                                  Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <PivotItem Header="Jira">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8" Padding="4,8,4,16">
                    <TextBox x:Name="JiraSite" Header="Site URL"
                             PlaceholderText="https://your-company.atlassian.net" />
                    <TextBox x:Name="JiraEmail" Header="Email" />
                    <PasswordBox x:Name="JiraToken" Header="API token (NO tu password)"
                                 PasswordRevealMode="Peek" />
                    <TextBox x:Name="JiraJql" Header="JQL del picker (nuevos worklogs)"
                             AcceptsReturn="True" TextWrapping="Wrap" />
                    <NumberBox x:Name="JiraIssueMax" Header="Máx. issues en el picker"
                               Minimum="10" Maximum="200" SpinButtonPlacementMode="Inline" />
                    <CheckBox x:Name="JiraShowSummary" Content="Mostrar el título del issue además de la key" />
                    <CheckBox x:Name="JiraDebug" Content="Loguear cada request a Debug Output" />
                </StackPanel>
            </ScrollViewer>
        </PivotItem>

        <PivotItem Header="Clockify">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="8" Padding="4,8,4,16">
                    <PasswordBox x:Name="ClockifyKey" Header="API key (Profile → Settings → API)"
                                 PasswordRevealMode="Peek" />
                    <TextBox x:Name="ClockifyWorkspace" Header="Workspace ID (opcional, se autoresuelve)" />
                    <TextBox x:Name="ClockifyDefaultProject" Header="Proyecto por defecto (ID) — usado por el sync Jira→Clockify" />
                    <CheckBox x:Name="ClockifyBillable" Content="Marcar como facturable por defecto" />
                    <CheckBox x:Name="ClockifyDebug" Content="Loguear cada request a Debug Output" />
                </StackPanel>
            </ScrollViewer>
        </PivotItem>
    </Pivot>
</ContentDialog>
