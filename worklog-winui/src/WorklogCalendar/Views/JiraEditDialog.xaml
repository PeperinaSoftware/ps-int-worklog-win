<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WorklogCalendar.Views.JiraEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Guardar"
    CloseButtonText="Cancelar"
    SecondaryButtonText="Eliminar"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">760</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">760</x:Double>
    </ContentDialog.Resources>
    <Grid Width="680">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Date + start/end pickers -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="DayPicker" Header="Día" Grid.Column="0" />
            <TimePicker x:Name="StartPicker" Header="Inicio" ClockIdentifier="24HourClock"
                        MinuteIncrement="5" Grid.Column="1" Margin="6,0,0,0" />
            <TimePicker x:Name="EndPicker" Header="Fin" ClockIdentifier="24HourClock"
                        MinuteIncrement="5" Grid.Column="2" Margin="6,0,0,0" />
            <TextBlock x:Name="DurationLabel" Grid.Column="3" VerticalAlignment="Bottom"
                       Margin="6,0,0,8" Opacity="0.7" />
        </Grid>

        <TextBlock Grid.Row="1" Text="Issue" Opacity="0.7" Margin="0,10,0,4" />
        <TextBlock x:Name="LockedIssue" Grid.Row="1" FontWeight="SemiBold"
                   TextWrapping="Wrap" Visibility="Collapsed" Margin="0,28,0,0" />

        <Grid Grid.Row="2" ColumnSpacing="6" x:Name="PickerSearchRow">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="IssueSearch" PlaceholderText="Filtrar issues..."
                            QueryIcon="Find" Grid.Column="0" />
            <Button x:Name="ReloadBtn" Content="↻" Grid.Column="1" ToolTipService.ToolTip="Recargar JQL" />
        </Grid>

        <ListView x:Name="IssueList" Grid.Row="4" SelectionMode="Single"
                  BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1" Margin="0,4,0,0"
                  MinHeight="220" MaxHeight="320">
            <ListView.ItemTemplate>
                <DataTemplate xmlns:m="using:WorklogCalendar.Models">
                    <Grid ColumnSpacing="8" Padding="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Key}" FontFamily="Consolas" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Summary}" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        <!-- "Subtarea · EN CURSO · 2h 30m" -->
                        <TextBlock Text="{Binding MetaDisplay}" Grid.Column="2"
                                   Opacity="0.6" FontSize="11" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Text="Comentario" Grid.Row="5" Opacity="0.7" Margin="0,10,0,4" />
        <TextBox x:Name="CommentBox" Grid.Row="6" AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="80" PlaceholderText="Notas opcionales..." />
    </Grid>
</ContentDialog>
