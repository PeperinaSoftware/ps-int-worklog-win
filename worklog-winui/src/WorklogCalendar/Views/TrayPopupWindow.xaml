<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WorklogCalendar.Views.TrayPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WorklogCalendar.Controls"
    Title="Worklog Calendar - Sprint">
    <Grid x:Name="Root"
          Background="#1F1F1F"
          RequestedTheme="Dark"
          Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Sprint actual"
                   Grid.Row="0"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Foreground="#FFFFFF"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8" />

        <controls:SprintGaugesControl x:Name="Gauges"
                                       Grid.Row="1"
                                       MinHeight="180" />

        <TextBlock Text="Click para abrir la app"
                   Grid.Row="2"
                   Foreground="#A0A0A0"
                   FontSize="10"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />
    </Grid>
</Window>
