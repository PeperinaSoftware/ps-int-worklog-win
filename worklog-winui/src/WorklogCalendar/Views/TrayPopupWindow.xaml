<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WorklogCalendar.Views.TrayPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WorklogCalendar.Controls"
    Title="Worklog">
    <!--
      Mica backdrop is set in code-behind; the root Grid uses a
      semi-transparent dark overlay so the Mica blur shows through.
    -->
    <Grid x:Name="Root"
          RequestedTheme="Dark"
          Padding="20,18,20,16">
        <Grid.RenderTransform>
            <CompositeTransform x:Name="RootTransform" TranslateY="24" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with title + drag handle dots -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Sprint actual"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Foreground="#F4F4F4"
                       VerticalAlignment="Center" />
            <FontIcon Grid.Column="1"
                      Glyph="&#xE721;"
                      FontSize="14"
                      Foreground="#888888"
                      VerticalAlignment="Center" />
        </Grid>

        <!-- The two ring gauges -->
        <controls:SprintGaugesControl x:Name="Gauges"
                                       Grid.Row="1"
                                       MinHeight="200"
                                       Margin="0,4,0,8" />

        <!-- Footer: hint text + close affordance -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Click para abrir la app"
                       Foreground="#A8A8A8"
                       FontSize="11"
                       HorizontalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
