<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WorklogCalendar.Views.ClockifyEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    PrimaryButtonText="Guardar"
    CloseButtonText="Cancelar"
    SecondaryButtonText="Eliminar"
    DefaultButton="Primary">
    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">760</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
    </ContentDialog.Resources>
    <Grid Width="680">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="DayPicker" Header="Día" />
            <TimePicker x:Name="StartPicker" Header="Inicio" ClockIdentifier="24HourClock"
                        MinuteIncrement="5" Grid.Column="1" Margin="6,0,0,0" />
            <TimePicker x:Name="EndPicker" Header="Fin" ClockIdentifier="24HourClock"
                        MinuteIncrement="5" Grid.Column="2" Margin="6,0,0,0" />
            <TextBlock x:Name="DurationLabel" Grid.Column="3" VerticalAlignment="Bottom"
                       Margin="6,0,0,8" Opacity="0.7" />
        </Grid>

        <TextBlock Grid.Row="1" Text="Proyecto" Opacity="0.7" Margin="0,10,0,4" />
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="ProjectSwatch" Width="14" Height="14" CornerRadius="2"
                    VerticalAlignment="Center" BorderBrush="#80FFFFFF" BorderThickness="1" />
            <ComboBox x:Name="ProjectCombo" Grid.Column="1" DisplayMemberPath="DisplayName"
                      HorizontalAlignment="Stretch" />
        </Grid>

        <TextBlock Grid.Row="3" Text="Tags" Opacity="0.7" Margin="0,10,0,4" />
        <ScrollViewer Grid.Row="4" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto" MaxHeight="120">
            <muxc:ItemsRepeater x:Name="TagsRepeater">
                <muxc:ItemsRepeater.Layout>
                    <muxc:StackLayout Orientation="Horizontal" Spacing="6" />
                </muxc:ItemsRepeater.Layout>
            </muxc:ItemsRepeater>
        </ScrollViewer>

        <CheckBox x:Name="BillableCheck" Content="Facturable (billable)" Grid.Row="5" Margin="0,8,0,0" />

        <TextBlock Text="Descripción" Grid.Row="6" Opacity="0.7" Margin="0,8,0,4" />
        <TextBox x:Name="DescBox" Grid.Row="7" AcceptsReturn="True"
                 TextWrapping="Wrap" MinHeight="80"
                 PlaceholderText="Qué hiciste en este intervalo" />
    </Grid>
</ContentDialog>
