<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WorklogCalendar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WorklogCalendar.Controls"
    Title="Worklog Calendar">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" Padding="10,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TitleText" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16" Margin="2,0,12,0" />
            <Button x:Name="PrevBtn" Content="◀" Grid.Column="1" ToolTipService.ToolTip="Semana anterior" />
            <Button x:Name="TodayBtn" Content="Hoy" Grid.Column="2" />
            <Button x:Name="NextBtn" Content="▶" Grid.Column="3" ToolTipService.ToolTip="Semana siguiente" />

            <TextBlock x:Name="WeekLabel" Grid.Column="4" HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontWeight="SemiBold" />

            <Button x:Name="ViewModeBtn" Content="Modo 9h" Grid.Column="5"
                    ToolTipService.ToolTip="Cambiar entre 09:00–18:00 y 00:00–24:00" />
            <DropDownButton x:Name="SourceBtn" Grid.Column="6" Content="Jira">
                <DropDownButton.Flyout>
                    <MenuFlyout x:Name="SourceFlyout">
                        <MenuFlyoutItem Text="Jira" Tag="jira" Click="OnSourceChanged" />
                        <MenuFlyoutItem Text="Jira / Clockify" Tag="jira-clockify" Click="OnSourceChanged" />
                        <MenuFlyoutItem Text="Clockify" Tag="clockify" Click="OnSourceChanged" />
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <Button x:Name="RefreshBtn" Grid.Column="7" Content="↻" ToolTipService.ToolTip="Sincronizar (F5)" />
            <Button x:Name="DiagBtn" Grid.Column="8" Content="ⓘ" ToolTipService.ToolTip="Diagnóstico" />
            <Button x:Name="SettingsBtn" Grid.Column="9" Content="⚙" ToolTipService.ToolTip="Configurar..." />
        </Grid>

        <!-- ============ Status bar ============ -->
        <TextBlock x:Name="StatusLabel" Grid.Row="1" Padding="12,0,12,4"
                   Opacity="0.85" Visibility="Collapsed" FontSize="12" TextWrapping="Wrap" />

        <!-- ============ Calendar ============ -->
        <controls:WeekCalendarControl x:Name="Calendar" Grid.Row="2" Margin="6,4,6,4" />

        <!-- ============ Footer ============ -->
        <Grid Grid.Row="3" Padding="12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TotalsLabel" VerticalAlignment="Center" Opacity="0.75" FontSize="12" />
            <Border x:Name="SyncProjectSwatch" Width="12" Height="12" CornerRadius="2"
                    BorderBrush="#80FFFFFF" BorderThickness="1" VerticalAlignment="Center"
                    Grid.Column="1" Visibility="Collapsed" />
            <ComboBox x:Name="SyncProjectCombo" Grid.Column="2" MinWidth="200"
                      DisplayMemberPath="DisplayName" Visibility="Collapsed"
                      ToolTipService.ToolTip="Proyecto destino del sync Jira → Clockify" />
            <Button x:Name="SyncJiraToClockifyBtn" Grid.Column="3" Content="Jira → Clockify"
                    Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
