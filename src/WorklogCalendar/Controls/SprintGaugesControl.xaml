<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WorklogCalendar.Controls.SprintGaugesControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WorklogCalendar.Controls">
    <Grid x:Name="Root">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left decorative line -->
        <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                Background="#1AFFFFFF" Margin="8,0" />

        <!-- Sprint column -->
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="6">
            <TextBlock Text="Sprint" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" />
            <local:RingGauge x:Name="SprintRing" Diameter="110" Thickness="12" HorizontalAlignment="Center" />
            <TextBlock x:Name="SprintLegend" TextAlignment="Center" Opacity="0.75" FontSize="11" />
        </StackPanel>

        <!-- Middle decorative line -->
        <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                Background="#1AFFFFFF" Margin="8,0" />

        <!-- Horas column -->
        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="6">
            <TextBlock Text="Horas" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" />
            <local:RingGauge x:Name="HoursRing" Diameter="110" Thickness="12" HorizontalAlignment="Center"
                             UseFadeLoop="True" />
            <TextBlock x:Name="HoursLegend" TextAlignment="Center" Opacity="0.75" FontSize="11" />
        </StackPanel>

        <!-- Right decorative line -->
        <Border Grid.Column="4" Height="1" VerticalAlignment="Center"
                Background="#1AFFFFFF" Margin="8,0" />
    </Grid>
</UserControl>
