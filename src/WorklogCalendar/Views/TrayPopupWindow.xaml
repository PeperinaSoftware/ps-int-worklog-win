<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WorklogCalendar.Views.TrayPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WorklogCalendar.Controls"
    Title="Worklog · Jira / Clockify">
    <!-- Mica is applied in code-behind; the Grid keeps a fallback dark fill. -->
    <Grid x:Name="Root"
          RequestedTheme="Dark"
          Padding="12,10,12,12">
        <Grid.RenderTransform>
            <CompositeTransform x:Name="RootTransform" TranslateY="24" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0 header -->
            <RowDefinition Height="Auto" />  <!-- 1 status -->
            <RowDefinition Height="*"   />  <!-- 2 calendar -->
            <RowDefinition Height="Auto" />  <!-- 3 gauges -->
            <RowDefinition Height="Auto" />  <!-- 4 totals -->
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" ColumnSpacing="6" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TitleText"
                       Text="Jira / Clockify"
                       FontWeight="SemiBold" FontSize="14"
                       VerticalAlignment="Center"
                       Margin="2,0,10,0" />

            <Button x:Name="PrevBtn" Grid.Column="1" Content="◀"
                    ToolTipService.ToolTip="Semana anterior" />
            <Button x:Name="TodayBtn" Grid.Column="2" Content="Hoy" />
            <Button x:Name="NextBtn" Grid.Column="3" Content="▶"
                    ToolTipService.ToolTip="Semana siguiente" />

            <TextBlock x:Name="WeekLabel" Grid.Column="4"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />

            <Button x:Name="RefreshBtn" Grid.Column="5" Content="↻"
                    ToolTipService.ToolTip="Sincronizar" />
            <Button x:Name="OpenMainBtn" Grid.Column="6"
                    Content="Abrir app ↗"
                    ToolTipService.ToolTip="Abre la ventana principal (cambiar modo, configurar, etc.)" />
        </Grid>

        <!-- ============ Status ============ -->
        <TextBlock x:Name="StatusLabel" Grid.Row="1"
                   Padding="4,2,4,4" FontSize="11"
                   Opacity="0" TextWrapping="Wrap" Text=" " />

        <!-- ============ Calendar ============ -->
        <controls:WeekCalendarControl x:Name="Calendar"
                                       Grid.Row="2"
                                       Margin="0,0,0,4" />

        <!-- ============ Gauges (compact) ============ -->
        <controls:SprintGaugesControl x:Name="Gauges"
                                       Grid.Row="3"
                                       Height="150"
                                       Margin="0,4,0,2" />

        <!-- ============ Totals + sync footer (combined mode shows Jira→Clockify) ============ -->
        <Grid Grid.Row="4" ColumnSpacing="6" Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TotalsLabel" Grid.Column="0"
                       VerticalAlignment="Center"
                       Opacity="0.75" FontSize="11" />
            <Button x:Name="SyncJiraToClockifyBtn" Grid.Column="1"
                    Content="Jira → Clockify"
                    Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
